  "keyFeatures": [
    "Offline Speech-to-Text (STT) with multiple model types",
    "Online streaming Speech-to-Text with real-time recognition",
    "Text-to-Speech (TTS) with multiple voice models",
    "Streaming Text-to-Speech for low-latency generation",
    "Voice Activity Detection (VAD)",
    "Speaker Diarization",
    "Speech Enhancement and Source Separation",
    "Hardware acceleration support (NNAPI, XNNPACK, Core ML, QNN)",
    "Model download manager with automatic extraction",
    "Play Asset Delivery (PAD) support for Android",
    "TypeScript support with full type definitions",
    "Cross-platform support for iOS and Android"
  ],
  "publicApiSurface": [
    "createSTT() - Create STT engine instance",
    "createStreamingSTT() - Create streaming STT engine",
    "createTTS() - Create TTS engine instance",
    "createStreamingTTS() - Create streaming TTS engine",
    "detectSttModel() - Detect STT model type",
    "detectTtsModel() - Detect TTS model type",
    "testSherpaInit() - Test native library initialization",
    "getQnnSupport() - Check QNN acceleration support",
    "getNnapiSupport() - Check NNAPI acceleration support",
    "getXnnpackSupport() - Check XNNPACK support",
    "getCoreMlSupport() - Check Core ML support",
    "getAvailableProviders() - List available execution providers",
    "ModelDownloadManager - Download and manage models",
    "assetModelPath() - Reference bundled asset models",
    "fileModelPath() - Reference file system models",
    "autoModelPath() - Auto-detect model location",
    "listAssetModels() - List bundled models",
    "listModelsAtPath() - List models at file path"
